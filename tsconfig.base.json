{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mednexus/shared/types": ["libs/shared/types/src/index.ts"],
      "@mednexus/shared/firebase": ["libs/shared/firebase/src/index.ts"],
      "@mednexus/shared/ui": ["libs/shared/ui/src/index.ts"],
      "@mednexus/shared/data-access": ["libs/shared/data-access/src/index.ts"],
      "@mednexus/shared/utils": ["libs/shared/utils/src/index.ts"],
      "@mednexus/auth/feature": ["libs/auth/feature/src/index.ts"],
      "@mednexus/auth/data-access": ["libs/auth/data-access/src/index.ts"],
      "@mednexus/patients/feature": ["libs/patients/feature/src/index.ts"],
      "@mednexus/patients/data-access": ["libs/patients/data-access/src/index.ts"],
      "@mednexus/dashboard/feature": ["libs/dashboard/feature/src/index.ts"],
      "@mednexus/analytics/feature": ["libs/analytics/feature/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
