{
  "name": "@mednexus/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:remotes": "nx run-many -t build --projects=auth,dashboard,analytics,patients",
    "watch:remotes": "nx run-many -t build --projects=auth,dashboard,analytics,patients --watch",
    "preview:remotes": "concurrently \"nx preview auth\" \"nx preview dashboard\" \"nx preview analytics\" \"nx preview patients\"",
    "dev": "pnpm build:remotes && concurrently -c auto -n watch,preview,shell \"pnpm watch:remotes\" \"pnpm preview:remotes\" \"nx serve shell\"",
    "start": "nx run-many -t serve --all"
  },
  "private": true,
